# API Configuration
# Copy this file to .env.local and set your API base URL
# NEVER commit .env.local to git - it's already excluded in .gitignore

# Local development (XAMPP: API runs at root)
VITE_API_URL=http://localhost/api

# Production (uncomment and use .env.production instead)
# VITE_API_URL=https://danvion.com/api

# Admin Configuration (format: email:role)
VITE_ADMIN_CONFIG=admin@example.com:admin
