rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone can READ public content
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogs/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /home_page/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /services_page/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /team_members/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /about_page/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Contact form: anyone can submit, only admin can read
    match /contact_messages/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
